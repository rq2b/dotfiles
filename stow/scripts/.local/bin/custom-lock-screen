#!/bin/bash

# Locks the system using hyprlock, but not before ensuring keepassxc has also been locked, and the screensaver stopped.

# Lock the screen
pidof hyprlock || hyprlock &

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure keepassxc is locked
if pgrep -x "keepassxc" >/dev/null; then
  keepassxc --lock &
fi

# Avoid running screensaver when locked
pkill -f org.omarchy.screensaver
